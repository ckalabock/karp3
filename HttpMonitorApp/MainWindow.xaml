<Window x:Class="HttpMonitorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HTTP Monitor Studio"
        Width="1420"
        Height="920"
        MinWidth="1200"
        MinHeight="760"
        Background="#F4F7FB">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#24304A" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Background" Value="#2B67F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#DFE6F5" />
            <Setter Property="Foreground" Value="#24304A" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="BorderBrush" Value="#CAD5EA" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="BorderBrush" Value="#CAD5EA" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,16" Padding="24" Background="#182033">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="Система мониторинга HTTP-запросов" />
                    <TextBlock Margin="0,8,0,0" FontSize="14" Foreground="#D1DBF0" Text="WPF-приложение с HTTP-сервером, клиентом, аналитикой и журналированием." />
                </StackPanel>
                <Border Grid.Column="1" Padding="14,10" Background="#26314A" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="#9FB0D6" Text="Состояние сервера" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="White" Text="{Binding ServerStateText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,16,0" Padding="22" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22" FontWeight="Bold" Text="Сервер и аналитика" />
                    <Grid Grid.Row="1" Margin="0,18,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Порт сервера" />
                            <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,14,10">
                            <Button Width="140" Command="{Binding StartServerCommand}" Content="Запустить" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,14,10">
                            <Button Width="140" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding StopServerCommand}" Content="Остановить" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="0,0,0,10" VerticalAlignment="Bottom">
                            <TextBlock FontWeight="SemiBold" Text="Комментарий" />
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#5B6885" Text="{Binding StatusMessage}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="16" Background="#F8FAFD" BorderBrush="#E1E8F5" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Текущая статистика" />
                                <DataGrid Grid.Row="1" Margin="0,12,0,0" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" ItemsSource="{Binding Statistics}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*" Header="Показатель" Binding="{Binding Name}" />
                                        <DataGridTextColumn Width="*" Header="Значение" Binding="{Binding Value}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Padding="16" Background="#F8FAFD" BorderBrush="#E1E8F5" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="190" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="График нагрузки" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Период" />
                                        <ComboBox ItemsSource="{Binding GranularityOptions}" SelectedItem="{Binding SelectedGranularity, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="1" Margin="0,10,0,0" Foreground="#5B6885" Text="Отображается интенсивность входящих запросов по последним временным интервалам." />
                                <Border Grid.Row="2" Margin="0,16,0,0" Padding="14" Background="White" BorderBrush="#E1E8F5" BorderThickness="1">
                                    <ItemsControl ItemsSource="{Binding LoadChart}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="6,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="150" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" VerticalAlignment="Bottom">
                                                        <Border VerticalAlignment="Bottom" Height="{Binding Height}" Background="#2B67F6" CornerRadius="10,10,0,0" />
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Margin="0,8,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding Count}" />
                                                    <TextBlock Grid.Row="2" Margin="0,6,0,0" HorizontalAlignment="Center" Foreground="#5B6885" Text="{Binding Label}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="22" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22" FontWeight="Bold" Text="HTTP-клиент" />
                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="URL запроса" />
                        <TextBox Text="{Binding ClientUrl, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Метод" />
                            <ComboBox ItemsSource="{Binding HttpMethods}" SelectedItem="{Binding SelectedHttpMethod, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Тело запроса JSON" />
                            <TextBox Height="140" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Text="{Binding RequestBody, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,14">
                        <Button Width="180" Command="{Binding SendRequestCommand}" Content="Отправить запрос" />
                    </StackPanel>
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ответ" />
                        <TextBox Grid.Row="1" Margin="0,12,0,0" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Text="{Binding ResponseBody}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="22" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock FontSize="22" FontWeight="Bold" Text="Логи запросов и ответов" />
                <Grid Grid.Row="1" Margin="0,18,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Фильтр по методу" />
                        <ComboBox ItemsSource="{Binding LogMethodFilters}" SelectedItem="{Binding SelectedLogMethodFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Фильтр по статусу" />
                        <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <TextBlock FontWeight="SemiBold" Text="Файл логов" />
                        <TextBlock Margin="0,6,0,0" Foreground="#5B6885" Text="{Binding LogFilePath}" />
                    </StackPanel>
                </Grid>
                <TextBox Grid.Row="2" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" Text="{Binding LogsText}" />
            </Grid>
        </Border>
    </Grid>
</Window>
